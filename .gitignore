*~
*.bak
*.orig
*.old
*.backup

# Magento 2.4+ specific
/magento/.gitlab-ci.yml
/magento/.travis.yml
/magento/.phpunit.result.cache

# Security sensitive files
/magento/app/etc/config.php.bak
/magento/app/etc/env.php.bak
/magento/auth.json.bak
**/config.php.bak
**/env.php.bak

# MacOS specific
.AppleDouble
.LSOverride
._*
.Spotlight-V100
.Trashes
.fseventsd

